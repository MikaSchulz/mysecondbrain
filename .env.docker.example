# .env.docker — kopieren nach .env.docker, ausfüllen. Wird von docker-compose als Container-ENV genutzt.
TZ=Europe/Berlin

# Claude ABO-Token (KEIN API-Key!). Holen:  claude setup-token  (auf bel. Rechner)
CLAUDE_CODE_OAUTH_TOKEN=
KB_MODEL=haiku

# Radicale (CalDAV)
RADICALE_USER=kb
RADICALE_PW=change-me

# ntfy (Basic-Auth)
NTFY_USER=kb
NTFY_PASSWORD=change-me
NTFY_TOPIC=kb

# Kosten/Caps
MONTH_BUDGET_USD=18
MIN_AGE=1800
MAX_RUNS_DAY=10

# Tailscale (optional — für Zugriff übers Tailnet). Authkey: Tailscale Admin -> Settings -> Keys
TS_AUTHKEY=
TS_HOSTNAME=kb
