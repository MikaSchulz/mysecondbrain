# /opt/kb/.env  — chmod 600, NIE ins git committen
# ============================================================
# Claude (ABO, nicht API!). Token via:  claude setup-token
export CLAUDE_CODE_OAUTH_TOKEN="paste-1y-oauth-token-here"
# ANTHROPIC_API_KEY hier NIEMALS setzen — run.sh unsetzt es zusätzlich.

# Modell für headless-Routine
export KB_MODEL="haiku"
export KB_MAX_TURNS="30"

# Radicale (CalDAV, localhost)
export RADICALE_URL="http://localhost:5232"
export RADICALE_USER="kb"
export RADICALE_PW="change-me"
export RADICALE_CALENDAR="routine"     # Collection-Name

# ntfy (localhost)
export NTFY_URL="http://localhost:8080"
export NTFY_TOPIC="kb"
export NTFY_TOKEN="tk_change_me"

# guard / Kosten
export MIN_AGE="1800"          # Sammelfenster: ältestes raw-Item ≥ Sekunden (1800=30min)
export COOLDOWN="1800"         # Mindestabstand zwischen Runs (Sekunden)
export MAX_RUNS_DAY="10"       # Tages-Cap
export MONTH_BUDGET_USD="18"   # Budget-Gate (unter $20-Pool)
export MAX_ITEMS_PER_RUN="20"  # Input-Cap

# Haiku-Preise ($/Mtok) für cost-watch (anpassen falls geändert)
export PRICE_IN_PER_MTOK="1.0"
export PRICE_OUT_PER_MTOK="5.0"

# whisper.cpp (Phase 2)
export WHISPER_BIN="/opt/whisper.cpp/main"
export WHISPER_MODEL="/opt/whisper.cpp/models/ggml-small.bin"
export WHISPER_LANG="de"

# Pfade
export KB_HOME="/opt/kb"
export VAULT="/opt/kb/vault"
